{
  "name": "line-pulse",
  "description": "Quickly count GitHub repo lines of code",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "wasm:build": "wasm-pack build ./wasm --target bundler --out-dir pkg",
    "dev": "bun run wasm:build && wxt",
    "dev:firefox": "bun run wasm:build && wxt -b firefox",
    "build": "bun run wasm:build && wxt build",
    "build:firefox": "bun run wasm:build && wxt build -b firefox",
    "zip": "bun run wasm:build && wxt zip",
    "zip:firefox": "bun run wasm:build && wxt zip -b firefox",
    "postinstall": "wxt prepare"
  },
  "dependencies": {
    "fflate": "^0.8.2",
    "lucide-vue-next": "^1.0.0",
    "picomatch": "^4.0.4",
    "vue": "^3.5.25"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.2.2",
    "@types/picomatch": "^4.0.3",
    "@wxt-dev/module-vue": "^1.0.3",
    "typescript": "^5.9.3",
    "wxt": "^0.20.6"
  }
}
